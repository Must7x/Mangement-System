@startuml mawared-actors
' MTNIMA — Mawared System Actors (Dynamic RBAC)

skinparam actorStyle awesome
skinparam shadowing false
skinparam defaultFontName Arial

title Mawared — System & Operational Actors

legend right
  |= Color |= Meaning |
  | <#E8F5E9> | **System login actor** — users.role_id |
  | <#E3F2FD> | **Operational actor** — no login |
endlegend

actor "Technical Administrator\n(Mas'ool Taqni)" as TA #E8F5E9
actor "Inventory Supervisor\n(Mushrif al-Makhzun)" as IS #E8F5E9
actor "Warehouse Keeper\n(Ameen al-Makhzan)" as WK #E8F5E9

actor "Department Manager\n(Mudeer al-Qism)" as DM #E3F2FD
actor "Employee\n(Muwazzaf)" as EM #E3F2FD
actor "Maintenance Technician\n(Fanni al-Siyana)" as MT #E3F2FD

rectangle "Mawared Application\n(Laravel — MTNIMA)" as SYS {

  usecase "Authenticate\n(/login)" as UC_LOGIN
  usecase "Manage users\n(/users)" as UC_USERS
  usecase "Manage roles & permissions\n(/roles)" as UC_ROLES
  usecase "System settings\n(/settings)" as UC_SETTINGS
  usecase "Manage inventory & assets" as UC_INV
  usecase "Manage assignments" as UC_ASSIGN
  usecase "Manage maintenance" as UC_MAINT
  usecase "Manage departments" as UC_DEPT
  usecase "Manage employee records" as UC_EMP
  usecase "View dashboard & reports" as UC_REPORT

}

TA --> UC_LOGIN
IS --> UC_LOGIN
WK --> UC_LOGIN

TA --> UC_USERS
TA --> UC_ROLES
TA --> UC_SETTINGS

IS --> UC_INV
IS --> UC_ASSIGN
IS --> UC_MAINT
IS --> UC_DEPT
IS --> UC_EMP
IS --> UC_REPORT

WK --> UC_INV
WK --> UC_ASSIGN
WK --> UC_MAINT
WK --> UC_REPORT

DM ..> UC_DEPT : <<operational>>\ndepartments table
EM ..> UC_ASSIGN : <<operational>>\nemployees table
EM ..> UC_EMP
MT ..> UC_MAINT : <<operational>>\ntechnician_name

note bottom of TA
  **System role:** technical_admin
  Users, roles, permissions, settings only
end note

note bottom of IS
  **System role:** inventory_supervisor
  Full operational access + org structure
end note

note bottom of WK
  **System role:** warehouse_keeper
  Daily ops — no asset delete or org CRUD
end note

@enduml
